{
  "manifest_version": 3,
  "name": "Listen Carefully",
  "version": "1.1.4",
  "description": "Stop reading. Start listening. Word-tracked TTS that breaks through text walls and cognitive overload.",
  "author": "Shiva Kerdel",
  "homepage_url": "https://github.com/s-kerdel/listen-carefully",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "optional_host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16-neutral.png",
      "48": "icons/icon-48-neutral.png",
      "128": "icons/icon-128-neutral.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["lib/config.js", "lib/text-extractor.js", "lib/tts-engine.js", "lib/highlighter.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16-neutral.png",
    "48": "icons/icon-48-neutral.png",
    "128": "icons/icon-128-neutral.png"
  }
}
